@page "/farmer/dashboard"
@page "/admin/panel"
@attribute [Authorize]

<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;background:#E8F5E9;font-family:Poppins,sans-serif;">
    <div style="background:#fff;border-radius:16px;padding:2rem;max-width:400px;width:90%;text-align:center;box-shadow:0 8px 24px rgba(0,0,0,.1);">
        <div style="font-size:3rem;">🌾</div>
        <h2 style="color:#1B5E20;margin-top:0.5rem;">Login Successful!</h2>
        <p style="color:#555;">Welcome to <strong>AGRI-SMART</strong>. You are now logged in.</p>
        <hr />
        <p style="font-size:0.85rem;color:#888;">This project demo includes only Login &amp; Register pages.</p>
        <a href="/logout" style="display:inline-block;margin-top:1rem;padding:0.75rem 2rem;background:#D32F2F;color:#fff;border-radius:50px;text-decoration:none;font-weight:600;">Logout</a>
    </div>
</div>
