@page "/login-otp"
@model AgriSmart.Web.Pages.Account.LoginOtpModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#1B5E20" />
    <meta name="description" content="Sign in to AgriSmart with email verification code." />
    <title>Email Verification — AGRI-SMART</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/mobile.css" rel="stylesheet" />
    <link href="~/css/app.css" rel="stylesheet" />
    <link href="~/css/open-iconic/font/css/open-iconic-bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        :root {
            --ag-green: #1B5E20;
            --ag-green-mid: #2E7D32;
            --ag-green-light: #43A047;
            --ag-blue: #1565C0;
            --ag-blue-mid: #1976D2;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Poppins', sans-serif;
            background: #0d1b0f;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Animated background */
        .login-bg {
            min-height: 100vh;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            position: relative;
            background: linear-gradient(135deg, #0a1f0a 0%, #0d2b1a 40%, #0a1a2e 100%);
            overflow: hidden;
        }

        .login-bg::before {
            content: '';
            position: absolute;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(46,125,50,0.18) 0%, transparent 70%);
            top: -150px;
            left: -150px;
            animation: pulse-glow 6s ease-in-out infinite;
        }

        .login-bg::after {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(21,101,192,0.15) 0%, transparent 70%);
            bottom: -100px;
            right: -100px;
            animation: pulse-glow 6s ease-in-out infinite 3s;
        }

        @@keyframes pulse-glow {
            0%, 100% { transform: scale(1); opacity: 0.7; }
            50% { transform: scale(1.15); opacity: 1; }
        }

        /* Floating leaves */
        .leaf {
            position: absolute;
            opacity: 0.08;
            animation: float 8s ease-in-out infinite;
            font-size: 2rem;
        }
        .leaf:nth-child(1) { top: 10%; left: 5%; animation-delay: 0s; }
        .leaf:nth-child(2) { top: 30%; right: 8%; animation-delay: 2s; }
        .leaf:nth-child(3) { bottom: 20%; left: 10%; animation-delay: 4s; }
        .leaf:nth-child(4) { top: 60%; right: 5%; animation-delay: 1s; }
        .leaf:nth-child(5) { bottom: 10%; right: 20%; animation-delay: 3s; }

        @@keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            33% { transform: translateY(-20px) rotate(10deg); }
            66% { transform: translateY(10px) rotate(-5deg); }
        }

        /* Card layout */
        .login-card-outer {
            width: 100%;
            max-width: 420px;
            position: relative;
            z-index: 10;
            animation: slide-up 0.6s cubic-bezier(0.34,1.56,0.64,1) both;
        }

        @@keyframes slide-up {
            from { opacity: 0; transform: translateY(40px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .brand-section {
            text-align: center;
            margin-bottom: 1.5rem;
        }

        .brand-logo-wrap {
            width: 84px;
            height: 84px;
            margin: 0 auto 0.75rem;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(46,125,50,0.45), 0 2px 8px rgba(0,0,0,0.5);
            border: 2px solid rgba(255,255,255,0.12);
        }

        .brand-logo-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .brand-name {
            font-size: 1.6rem;
            font-weight: 800;
            letter-spacing: 0.05em;
            line-height: 1;
        }

        .brand-name .agri { color: #66BB6A; }
        .brand-name .smart { color: #42A5F5; }

        .login-form-card {
            background: rgba(255,255,255,0.06);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 24px;
            padding: 1.75rem;
            box-shadow: 0 24px 64px rgba(0,0,0,0.5);
        }

        .card-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 0.25rem;
        }

        .card-subtitle {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.45);
            margin-bottom: 1.25rem;
        }

        .error-alert {
            background: rgba(211,47,47,0.2);
            border: 1px solid rgba(239,83,80,0.5);
            color: #EF9A9A;
            border-radius: 10px;
            padding: 0.65rem 0.85rem;
            font-size: 0.82rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .success-alert {
            background: rgba(46,125,50,0.2);
            border: 1px solid rgba(102,187,106,0.5);
            color: #A5D6A7;
            border-radius: 10px;
            padding: 0.65rem 0.85rem;
            font-size: 0.82rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .field-group {
            margin-bottom: 1.25rem;
        }

        .field-label {
            display: block;
            font-size: 0.78rem;
            font-weight: 600;
            color: rgba(255,255,255,0.65);
            margin-bottom: 0.4rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .field-wrap {
            position: relative;
        }

        .field-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.35);
            font-size: 0.9rem;
            pointer-events: none;
        }

        .field-input {
            width: 100%;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 12px;
            color: #fff;
            font-size: 0.95rem;
            padding: 0.75rem 1rem 0.75rem 2.75rem;
            transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
            font-family: 'Poppins', sans-serif;
            min-height: 48px;
            outline: none;
        }

        .field-input::placeholder { color: rgba(255,255,255,0.25); }

        .field-input:focus {
            border-color: rgba(102,187,106,0.6);
            background: rgba(255,255,255,0.12);
            box-shadow: 0 0 0 3px rgba(102,187,106,0.15);
        }

        .btn-submit {
            width: 100%;
            background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
            color: #fff;
            border: none;
            border-radius: 12px;
            padding: 0.85rem 1rem;
            font-size: 0.95rem;
            font-weight: 700;
            font-family: 'Poppins', sans-serif;
            letter-spacing: 0.04em;
            cursor: pointer;
            transition: transform 0.15s, box-shadow 0.15s;
            box-shadow: 0 4px 16px rgba(46,125,50,0.4);
            min-height: 48px;
        }

        .btn-submit:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(46,125,50,0.5);
        }

        .back-to-login {
            text-align: center;
            margin-top: 1.25rem;
            font-size: 0.85rem;
        }

        .back-to-login a {
            color: #66BB6A;
            font-weight: 700;
            text-decoration: none;
            transition: color 0.2s;
        }

        .back-to-login a:hover { color: #A5D6A7; }
    </style>
</head>
<body>
    <div class="login-bg">
        <span class="leaf">🌿</span>
        <span class="leaf">🌱</span>
        <span class="leaf">🍃</span>
        <span class="leaf">🌾</span>
        <span class="leaf">🌿</span>

        <div class="login-card-outer">
            <div class="brand-section">
                <div class="brand-logo-wrap">
                    <img src="~/images/logo.jpg" alt="AgriSmart Logo" />
                </div>
                <div class="brand-name">
                    <span class="agri">AGRI</span><span class="smart">SMART</span>
                </div>
            </div>

            <form method="post" class="login-form-card" id="otpForm" onsubmit="return onOtpSubmit()">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Step" />

                @if (!string.IsNullOrEmpty(Model.DemoOtpCode))
                {
                    <div class="alert alert-warning text-dark text-center my-3" style="border-radius: 12px; background: rgba(255, 193, 7, 0.15); border: 1px solid rgba(255, 193, 7, 0.4); color: #ffe082 !important; font-family: 'Poppins', sans-serif;">
                        <span class="oi oi-info" style="margin-right: 6px;"></span> 
                        <strong>Demo Mode OTP:</strong> <span style="font-size: 1.4rem; font-weight: 800; letter-spacing: 0.1em; color: #fff; background: rgba(0,0,0,0.2); padding: 2px 8px; border-radius: 6px; margin-left: 6px;">@Model.DemoOtpCode</span>
                    </div>
                }

                @if (Model.Step == 1)
                {
                    <div class="card-title">Sign In with OTP 🔑</div>
                    <div class="card-subtitle">Enter your email to receive a 6-digit code.</div>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="error-alert">
                            <span class="oi oi-warning"></span>
                            @Model.ErrorMessage
                        </div>
                    }

                    <div class="field-group">
                        <label class="field-label" asp-for="Email">Email Address</label>
                        <div class="field-wrap">
                            <span class="field-icon oi oi-envelope-closed"></span>
                            <input class="field-input" asp-for="Email" type="email" placeholder="name@domain.com" required />
                        </div>
                    </div>

                    <button type="submit" class="btn-submit" id="submitBtn">
                        <span id="submitBtnText">Send Verification Code</span>
                        <div class="spinner-border spinner-border-sm text-light ms-2" id="submitSpinner" style="display:none; vertical-align: middle;" role="status"></div>
                    </button>
                }
                else
                {
                    <div class="card-title">Enter Verification Code 💬</div>
                    <div class="card-subtitle">We sent a 6-digit code to <strong>@Model.Email</strong>.</div>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="error-alert">
                            <span class="oi oi-warning"></span>
                            @Model.ErrorMessage
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                    {
                        <div class="success-alert">
                            <span class="oi oi-check"></span>
                            @Model.SuccessMessage
                        </div>
                    }

                    <input type="hidden" asp-for="Email" />

                    <div class="field-group">
                        <label class="field-label" asp-for="OtpCode">6-Digit Code</label>
                        <div class="field-wrap">
                            <span class="field-icon oi oi-key"></span>
                            <input class="field-input text-center" style="letter-spacing: 0.5em; font-size: 1.3rem; font-weight: 700; padding-left: 1rem;" 
                                   asp-for="OtpCode" maxlength="6" minlength="6" placeholder="******" pattern="\d{6}" inputmode="numeric" required autofocus />
                        </div>
                    </div>

                    <button type="submit" class="btn-submit" id="submitBtn">
                        <span id="submitBtnText">Verify & Sign In</span>
                        <div class="spinner-border spinner-border-sm text-light ms-2" id="submitSpinner" style="display:none; vertical-align: middle;" role="status"></div>
                    </button>
                    
                    <div style="text-align: center; margin-top: 1rem;">
                        <a href="/login-otp" style="color: rgba(255,255,255,0.5); font-size: 0.8rem; text-decoration: none;">Resend code</a>
                    </div>
                }

                <div class="back-to-login">
                    <a href="/login">← Back to Password Login</a>
                </div>
            </form>
        </div>
    </div>

    <script>
        function onOtpSubmit() {
            const btn = document.getElementById('submitBtn');
            const spinner = document.getElementById('submitSpinner');
            const text = document.getElementById('submitBtnText');
            
            spinner.style.display = 'inline-block';
            if (text.textContent.indexOf('Verify') >= 0) {
                text.textContent = 'Verifying...';
            } else {
                text.textContent = 'Sending...';
            }
            btn.style.pointerEvents = 'none';
            btn.setAttribute('disabled', 'disabled');
            return true;
        }
    </script>
</body>
</html>
