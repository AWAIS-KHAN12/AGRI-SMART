@page "/login"
@model AgriSmart.Web.Pages.Account.LoginModel
@using System.Linq
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#1976D2" />
    <title>Login — AGRI-SMART</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/css/app.css" rel="stylesheet" />
    <link href="~/css/open-iconic/font/css/open-iconic-bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/icons.css" rel="stylesheet" />
</head>
<body>
    <form method="post" class="auth-login-page">
        @Html.AntiForgeryToken()
        <div class="brand-header">
            <img src="~/images/logo.jpg" alt="Agri Smart Logo" style="width: 140px; height: 140px; object-fit: contain; border-radius: 24px; box-shadow: 0 4px 12px rgba(0,0,0,.15); margin-bottom: 0.75rem;" />
            <div class="brand-tagline" style="margin-top: 0.25rem;">(a smart agricultural advisory system)</div>
        </div>

        <div class="login-card">
            <h2>Welcome back!</h2>
            <div class="mini-brand" style="display: flex; align-items: center; gap: 0.5rem; font-weight: 700; color: #0D47A1; margin-bottom: 1rem; font-size: 0.85rem;"><img src="~/images/logo.jpg" alt="Logo" style="width: 24px; height: 24px; object-fit: contain; border-radius: 4px;" /> AGRI SMART</div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert-error">@Model.ErrorMessage</div>
            }
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div class="alert-error">@error.ErrorMessage</div>
            }

            <div class="input-group-agri">
                <label asp-for="Input.Username">Username or Email</label>
                <span class="input-icon"><span class="oi oi-person" aria-hidden="true"></span></span>
                <input asp-for="Input.Username" placeholder="Enter your email" />
            </div>

            <div class="input-group-agri">
                <label asp-for="Input.Password">Password</label>
                <span class="input-icon"><span class="oi oi-lock-locked" aria-hidden="true"></span></span>
                <input asp-for="Input.Password" type="password" placeholder="Enter your password" />
            </div>

            <div class="forgot-link"><a href="#">Forgot Password?</a></div>

            <div class="mb-2">
                <label>
                    <input asp-for="Input.RememberMe" type="checkbox" /> Remember Me
                </label>
            </div>

            <button type="submit" class="btn-pill-login">LOG IN</button>

            <div class="signup-prompt">Don't have an account? <a href="/register">Sign Up</a></div>

            <div class="social-login my-3">
                <div class="text-muted mb-2">Or connect with:</div>
                <div class="social-btns row g-2 justify-content-center">
                    <div class="col-6" style="max-width: 140px;">
                        <button type="button" class="btn btn-outline-danger w-100 d-flex align-items-center justify-content-center gap-2 py-2" style="border-radius: 8px; font-weight: 600;" onclick="simulateSocialLogin('Google')">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-google" viewBox="0 0 16 16">
                                <path d="M15.545 6.558a9.42 9.42 0 0 1 .139 1.626c0 2.434-.87 4.492-2.384 5.885h.002C11.978 15.292 10.158 16 8 16A8 8 0 1 1 8 0c2.204 0 4.07.813 5.485 2.13l-2.224 2.224C10.281 3.376 9.22 3 8 3c-2.427 0-4.5 1.629-5.234 3.826a4.99 4.99 0 0 0-.3 1.175c-.06.27-.093.552-.093.843s.032.573.093.843a4.978 4.978 0 0 0 .3 1.175c.734 2.197 2.807 3.826 5.234 3.826 1.38 0 2.538-.35 3.41-.975.83-.585 1.354-1.42 1.566-2.402H8v-3.2h7.545z"/>
                            </svg>
                            Google
                        </button>
                    </div>
                    <div class="col-6" style="max-width: 140px;">
                        <button type="button" class="btn btn-outline-primary w-100 d-flex align-items-center justify-content-center gap-2 py-2" style="border-radius: 8px; font-weight: 600;" onclick="simulateSocialLogin('Facebook')">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-facebook" viewBox="0 0 16 16">
                                <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951z"/>
                            </svg>
                            Facebook
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>

    <script>
        function simulateSocialLogin(provider) {
            const username = provider === "Google" ? "google_user" : "facebook_user";
            document.getElementById("Input_Username").value = username;
            document.getElementById("Input_Password").value = "OAuth@1234";
            document.querySelector("form").submit();
        }
    </script>
</body>
</html>
