@page "/farmer/pests"
@attribute [Authorize]
@inject PestDiseaseService PestDiseaseService

<h2 class="fs-4 fs-md-3 fw-bold mb-4">Pest &amp; Disease</h2>

<div class="mx-auto" style="max-width: 800px;">
    <div class="input-group mb-4 shadow-sm">
        <span class="input-group-text bg-white border-end-0"><span class="oi oi-magnifying-glass text-muted"></span></span>
        <input type="text" class="form-control border-start-0 ps-0" placeholder="Search pests or diseases..." @bind-value="_searchQuery" @bind-value:event="oninput" />
    </div>

    @{
        var filteredItems = PestDiseaseService.Search(_searchQuery);
        var pests = filteredItems.Where(x => x.Type == "Pest").ToList();
        var diseases = filteredItems.Where(x => x.Type == "Disease").ToList();
    }

    <h3 class="fs-5 fw-bold mb-3">Common Pests</h3>
    @if (!pests.Any())
    {
        <div class="alert alert-light text-muted fst-italic">No pests match your search.</div>
    }
    else
    {
        <div class="row g-3 mb-4">
            @foreach (var item in pests)
            {
                <div class="col-12 col-md-6">
                    <div class="card p-3 shadow-sm border-0 h-100 d-flex flex-row align-items-center" style="cursor: pointer;" @onclick="() => ShowDetail(item)">
                        <img src="@item.ImagePath" alt="@item.Name" class="rounded me-3" style="width: 60px; height: 60px; object-fit: cover;" />
                        <div class="flex-fill">
                            <div class="fw-bold text-dark fs-6 fs-md-5">@item.Name</div>
                            <div class="text-muted small text-truncate" style="max-width: 200px;">@item.ShortDescription</div>
                        </div>
                        <span class="oi oi-chevron-right text-muted ms-2"></span>
                    </div>
                </div>
            }
        </div>
    }

    <h3 class="fs-5 fw-bold mb-3">Common Diseases</h3>
    @if (!diseases.Any())
    {
        <div class="alert alert-light text-muted fst-italic">No diseases match your search.</div>
    }
    else
    {
        <div class="row g-3 mb-4">
            @foreach (var item in diseases)
            {
                <div class="col-12 col-md-6">
                    <div class="card p-3 shadow-sm border-0 h-100 d-flex flex-row align-items-center" style="cursor: pointer;" @onclick="() => ShowDetail(item)">
                        <img src="@item.ImagePath" alt="@item.Name" class="rounded me-3" style="width: 60px; height: 60px; object-fit: cover;" />
                        <div class="flex-fill">
                            <div class="fw-bold text-dark fs-6 fs-md-5">@item.Name</div>
                            <div class="text-muted small text-truncate" style="max-width: 200px;">@item.ShortDescription</div>
                        </div>
                        <span class="oi oi-chevron-right text-muted ms-2"></span>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_selectedItem != null)
{
    <div class="position-fixed top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex justify-content-end" style="z-index: 1050;" @onclick="HideDetail">
        <div class="bg-white h-100 shadow d-flex flex-column" style="width: 100%; max-width: 400px;" @onclick:stopPropagation>
            <div class="bg-danger text-white p-3 d-flex justify-content-between align-items-center">
                <h4 class="m-0 fs-5">@_selectedItem.Name (@_selectedItem.Type)</h4>
                <button class="btn-close btn-close-white" aria-label="Close" @onclick="HideDetail"></button>
            </div>
            
            <div class="p-3 overflow-auto flex-fill">
                <img src="@_selectedItem.ImagePath" alt="@_selectedItem.Name" class="w-100 rounded mb-3" style="height: 200px; object-fit: cover;" />

                <h5 class="fw-bold text-danger fs-6">Overview</h5>
                <p class="small text-dark mb-3">@_selectedItem.Description</p>

                <h5 class="fw-bold text-danger fs-6">Symptoms</h5>
                <p class="small text-dark mb-3">@_selectedItem.Symptoms</p>

                <h5 class="fw-bold text-danger fs-6">Management &amp; Control</h5>
                <div class="bg-light p-3 rounded border-start border-success border-4 small" style="white-space: pre-line;">
                    @_selectedItem.ControlMeasures
                </div>
            </div>
            
            <div class="p-3 border-top bg-light text-center">
                <button class="btn btn-danger w-100 fw-bold" @onclick="HideDetail">Close Details</button>
            </div>
        </div>
    </div>
}

@code {
    private string _searchQuery = "";
    private PestDiseaseItem _selectedItem;

    private void ShowDetail(PestDiseaseItem item)
    {
        _selectedItem = item;
    }

    private void HideDetail()
    {
        _selectedItem = null;
    }
}
