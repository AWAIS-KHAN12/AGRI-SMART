@page "/farmer/weather"
@attribute [Authorize]
@inject WeatherService WeatherService

<div class="app-shell">
    @* ── Header ── *@
    <header class="app-header orange">
        <a href="/farmer/dashboard" class="btn-icon" title="Back">
            <span class="oi oi-arrow-left"></span>
        </a>
        <h1>Weather</h1>
        <div style="width: 44px;"></div> @* Center helper spacer *@
    </header>

    @* ── Content ── *@
    <div class="app-content cream">
        @* City Dropdown selector *@
        <div class="filter-full" style="margin-bottom: 1.25rem;">
            <label for="city-select">Select Location</label>
            <select id="city-select" @bind="_selectedCity">
                @foreach (var city in PakistanData.Cities)
                {
                    <option value="@city">@city</option>
                }
            </select>
        </div>

        @if (_weatherData == null)
        {
            <div style="text-align: center; padding: 2rem;">
                <p>Loading weather data...</p>
            </div>
        }
        else
        {
            @* Location and Date *@
            <div class="weather-location">
                <span class="oi oi-location" style="color: var(--orange-weather);"></span>
                <span>@_weatherData.City, @_weatherData.Province</span>
            </div>
            <div class="weather-date">
                Today, @_currentDate
            </div>

            @* Current Temperature Details *@
            <div class="weather-main">
                <span class="weather-icon-lg">
                    <span class="oi @GetWeatherIconClass(_weatherData.Condition)" style="color: var(--orange-weather);"></span>
                </span>
                <div style="text-align: right;">
                    <div class="temp">@_weatherData.Temperature°c</div>
                    <div style="color: var(--text-muted); font-size: 0.9rem; font-weight: 500;">@_weatherData.Condition</div>
                </div>
            </div>

            @* Metrics Row *@
            <div class="weather-metrics">
                <div class="metric-card">
                    <span class="oi oi-droplet" style="color: #1976D2; font-size: 1.1rem; margin-bottom: 0.25rem; display: inline-block;"></span>
                    <span class="val">@_weatherData.Humidity%</span>
                    <span>Humidity</span>
                </div>
                <div class="metric-card">
                    <span class="oi oi-loop-circular" style="color: #4CAF50; font-size: 1.1rem; margin-bottom: 0.25rem; display: inline-block;"></span>
                    <span class="val">@_weatherData.WindSpeed km/h</span>
                    <span>Wind</span>
                </div>
                <div class="metric-card">
                    <span class="oi oi-dashboard" style="color: #795548; font-size: 1.1rem; margin-bottom: 0.25rem; display: inline-block;"></span>
                    <span class="val">@_weatherData.Pressure hPa</span>
                    <span>Pressure</span>
                </div>
            </div>

            @* Today's Forecast (Hourly) *@
            <h3 class="section-title">Today's Forecast</h3>
            <div class="forecast-scroll" style="margin-bottom: 1.5rem;">
                @foreach (var forecast in _weatherData.HourlyForecasts)
                {
                    <div class="hour-card">
                        <div style="margin-bottom: 0.25rem; color: var(--text-muted);">@forecast.Time</div>
                        <span class="oi @forecast.IconClass" style="font-size: 1.25rem; color: var(--orange-weather); margin: 0.35rem 0; display: inline-block;"></span>
                        <div style="font-weight: 700;">@forecast.Temperature°</div>
                    </div>
                }
            </div>

            @* 5 Day Forecast *@
            <h3 class="section-title">5 Day Forecast</h3>
            <div class="forecast-panel">
                @foreach (var dayForecast in _weatherData.DailyForecasts)
                {
                    <div class="forecast-day-row">
                        <div style="flex: 1; font-weight: 500;">@dayForecast.Day</div>
                        <div style="flex: 1; text-align: center;">
                            <span class="oi @dayForecast.IconClass" style="color: var(--orange-weather); font-size: 1.1rem;"></span>
                        </div>
                        <div style="flex: 1; text-align: right; font-weight: 700; color: var(--text-dark);">
                            @dayForecast.MaxTemp° / <span style="color: var(--text-muted); font-weight: 400;">@dayForecast.MinTemp°</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* ── Bottom Navigation ── *@
    <BottomNav ActiveTab="Weather" />
</div>

@code {
    private string _selectedCity = "Islamabad";
    private string _previousCity = "Islamabad";
    private string _currentDate = "";
    private WeatherData _weatherData;

    protected override async Task OnInitializedAsync()
    {
        _currentDate = DateTime.Now.ToString("dd MMM yyyy");
        await LoadWeatherAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_selectedCity != _previousCity)
        {
            _previousCity = _selectedCity;
            await LoadWeatherAsync();
        }
    }

    // Since Blazor doesn't always trigger OnParametersSetAsync for local fields, we can handle dynamic selection updates
    private string SelectedCity
    {
        get => _selectedCity;
        set
        {
            if (_selectedCity != value)
            {
                _selectedCity = value;
                InvokeAsync(async () => {
                    await LoadWeatherAsync();
                    StateHasChanged();
                });
            }
        }
    }

    // Force bind refresh
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_selectedCity != _previousCity)
        {
            _previousCity = _selectedCity;
            await LoadWeatherAsync();
            StateHasChanged();
        }
    }

    private async Task LoadWeatherAsync()
    {
        _weatherData = await WeatherService.GetWeatherAsync(_selectedCity);
    }

    private string GetWeatherIconClass(string condition)
    {
        if (string.IsNullOrWhiteSpace(condition)) return "oi-sun";
        return condition.ToLower() switch
        {
            var c when c.Contains("sun") || c.Contains("clear") => "oi-sun",
            var c when c.Contains("partly") => "oi-cloud",
            var c when c.Contains("cloud") => "oi-cloud",
            var c when c.Contains("rain") || c.Contains("drizzle") || c.Contains("shower") => "oi-rain",
            var c when c.Contains("snow") => "oi-bolt",
            _ => "oi-sun"
        };
    }
}
