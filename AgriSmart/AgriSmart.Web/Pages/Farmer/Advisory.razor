@page "/farmer/advisory"
@attribute [Authorize]
@inject AdvisoryService AdvisoryService

<h2 class="fs-4 fs-md-3 fw-bold mb-4">Advisory History</h2>

<div class="card p-3 p-md-4 mb-4 shadow-sm border-0 mx-auto" style="max-width: 800px;">
    <div class="row g-3 mb-3">
        <div class="col-12 col-md-6">
            <label for="date-from" class="form-label fw-bold">Date From</label>
            <input type="date" id="date-from" class="form-control" @bind="_dateFrom" />
        </div>
        <div class="col-12 col-md-6">
            <label for="date-to" class="form-label fw-bold">Date To</label>
            <input type="date" id="date-to" class="form-control" @bind="_dateTo" />
        </div>
    </div>

    <div class="mb-4">
        <label for="crop-select" class="form-label fw-bold">Crop</label>
        <select id="crop-select" class="form-select w-100" @bind="_selectedCrop">
            <option value="All Crops">All Crops</option>
            @foreach (var crop in _crops)
            {
                <option value="@crop">@crop</option>
            }
        </select>
    </div>

    <button class="btn btn-success w-100 py-2 fw-bold" @onclick="SearchAdvisories">Search</button>
</div>

@if (_filteredAdvisories == null)
{
    <div class="text-center p-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-3 text-muted">Loading advisories...</p>
    </div>
}
else if (!_filteredAdvisories.Any())
{
    <div class="alert alert-secondary text-center mx-auto" style="max-width: 800px;">
        No advisory history found matching the filters.
    </div>
}
else
{
    <div class="mx-auto" style="max-width: 800px;">
        @foreach (var advisory in _filteredAdvisories)
        {
            <div class="card p-3 p-md-4 mb-3 shadow-sm border-0">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="fw-bold fs-5 text-primary">@advisory.CropName</div>
                    <div class="text-muted small">@advisory.Date.ToString("dd MMM yyyy")</div>
                </div>
                <p class="mb-3">@advisory.Description</p>
                <div>
                    <span class="badge @GetTagClass(advisory.Tag)">@advisory.Tag</span>
                </div>
            </div>
        }
    </div>
}

@code {
    private DateTime? _dateFrom = new DateTime(2025, 5, 1);
    private DateTime? _dateTo = new DateTime(2025, 5, 20);
    private string _selectedCrop = "All Crops";

    private List<string> _crops = new List<string>();
    private List<AdvisoryRecord> _filteredAdvisories;

    protected override void OnInitialized()
    {
        _crops = AdvisoryService.GetCropNames();
        SearchAdvisories();
    }

    private void SearchAdvisories()
    {
        _filteredAdvisories = AdvisoryService.Search(_dateFrom, _dateTo, _selectedCrop);
    }

    private string GetTagClass(string tag)
    {
        return tag?.ToLower() switch
        {
            "fertilizer" => "bg-primary",
            "pest control" => "bg-danger",
            "irrigation" => "bg-info text-dark",
            "harvesting" => "bg-success",
            _ => "bg-secondary"
        };
    }
}
