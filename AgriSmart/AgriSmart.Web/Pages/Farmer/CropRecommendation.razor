@page "/farmer/crops"
@attribute [Authorize]
@inject AgriSmart.Web.Services.CropRecommendationService CropService

<h2 class="fs-4 fs-md-3 fw-bold mb-4">Crop Recommendation</h2>

<div class="card p-3 p-md-4 mb-4 shadow-sm border-0 mx-auto" style="max-width: 600px;">
    <div class="mb-3">
        <label class="form-label fw-bold">Region</label>
        <select class="form-select w-100" @bind="_selectedRegion">
            @foreach (var p in Helpers.PakistanData.Provinces)
            {
                <option value="@p">@p</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Season</label>
        <select class="form-select w-100" @bind="_selectedSeason">
            @foreach (var s in Helpers.PakistanData.Seasons)
            {
                <option value="@s">@s</option>
            }
        </select>
    </div>

    <div class="mb-4">
        <label class="form-label fw-bold">Soil Type</label>
        <select class="form-select w-100" @bind="_selectedSoil">
            @foreach (var t in Helpers.PakistanData.SoilTypes)
            {
                <option value="@t">@t</option>
            }
        </select>
    </div>

    <button class="btn btn-success w-100 py-2 fw-bold" @onclick="Search">Get Recommendations</button>
</div>

@if (_results != null && _results.Count > 0)
{
    <h3 class="fs-5 fw-bold mb-3">Recommended Crops</h3>
    <div class="row g-3">
        @foreach (var crop in _results)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card p-3 shadow-sm border-0 h-100 d-flex flex-row align-items-center">
                    <span class="bg-light text-success p-3 rounded-3 me-3">
                        <span class="oi @crop.IconClass fs-4"></span>
                    </span>
                    <div>
                        <div class="fw-bold fs-6 fs-md-5">@crop.Name</div>
                        <span class="badge @(crop.Suitability == "High" ? "bg-success" : "bg-warning text-dark") mb-1">
                            @crop.Suitability Suitability
                        </span>
                        <div class="text-muted small">Duration: @crop.Duration</div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (_searched)
{
    <div class="alert alert-secondary text-center mx-auto" style="max-width: 600px;">
        No crops found for the selected criteria. Try different filters.
    </div>
}

@code {
    private string _selectedRegion = "Punjab";
    private string _selectedSeason = "Kharif";
    private string _selectedSoil = "Loamy";
    private bool _searched;
    private List<AgriSmart.Web.Models.CropRecommendation> _results;

    private void Search()
    {
        _results = CropService.GetRecommendations(_selectedRegion, _selectedSeason, _selectedSoil);
        _searched = true;
    }
}
