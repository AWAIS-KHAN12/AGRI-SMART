@page "/admin/panel"
@attribute [Authorize(Roles = "Admin")]
@inject AdvisoryService AdvisoryService
@inject NavigationManager NavigationManager
@inject AgriSmart.Web.Services.AppState AppState
@implements IDisposable

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fs-4 fw-bold mb-0">@AppState.T("Admin Panel", "ایڈمن پینل")</h2>
    <div class="position-relative">
        <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleProfileMenu">
            <span class="oi oi-person me-1"></span> @AppState.T("Profile", "پروفائل")
        </button>
        @if (_showProfileMenu)
        {
            <div class="position-absolute end-0 mt-2 bg-white rounded shadow p-3" style="z-index: 1050; width: 220px;">
                <div class="fw-bold small">@AppState.T("Administrator", "سستم ایڈمنسٹریٹر")</div>
                <div class="text-muted small mb-2">admin@agrismart.pk</div>
                <hr class="my-2" />
                <a href="/logout" class="btn btn-danger btn-sm w-100">@AppState.T("Logout", "لاگ آؤٹ")</a>
            </div>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        @_errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" @onclick="ClearError"></button>
    </div>
}

@if (_loading)
{
    <div class="card p-5 shadow-sm border-0 text-center">
        <div class="spinner-border text-success mx-auto" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-3 text-muted mb-0">@AppState.T("Processing, please wait...", "پروسیسنگ ہو رہی ہے، براہ کرم انتظار کریں...")</p>
    </div>
}
else
{
    @if (_activeView == "None")
    {
        @* Stats *@
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card p-3 p-md-4 shadow-sm border-0 text-center h-100">
                    <span class="oi oi-people text-success fs-3 mb-2"></span>
                    <div class="fs-4 fw-bold text-success">125</div>
                    <div class="text-muted small">@AppState.T("Total Farmers", "کل کاشتکار")</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card p-3 p-md-4 shadow-sm border-0 text-center h-100">
                    <span class="oi oi-location text-primary fs-3 mb-2"></span>
                    <div class="fs-4 fw-bold text-primary">18</div>
                    <div class="text-muted small">@AppState.T("Active Regions", "فعال علاقے")</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card p-3 p-md-4 shadow-sm border-0 text-center h-100">
                    <span class="oi oi-lightbulb text-warning fs-3 mb-2"></span>
                    <div class="fs-4 fw-bold text-warning">@AdvisoryService.TotalAdvisories</div>
                    <div class="text-muted small">@AppState.T("Advisories", "کل مشورے")</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card p-3 p-md-4 shadow-sm border-0 text-center h-100">
                    <span class="oi oi-document fs-3 mb-2" style="color: #673AB7;"></span>
                    <div class="fs-4 fw-bold" style="color: #673AB7;">8</div>
                    <div class="text-muted small">@AppState.T("Reports", "رپورٹس")</div>
                </div>
            </div>
        </div>

        @* Management *@
        <h3 class="fs-5 fw-bold mb-3">@AppState.T("Management", "انتظام و انصرام")</h3>
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <button class="card p-3 shadow-sm border-0 w-100 text-start d-flex flex-row align-items-center" @onclick='() => SetView("DataGrid")' style="border: none; cursor: pointer;">
                    <span class="bg-light p-3 rounded-3 me-3" style="color: #673AB7;"><span class="oi oi-list-rich"></span></span>
                    <div class="flex-fill">
                        <div class="fw-bold">@AppState.T("Data Grid", "ڈیٹا گرڈ")</div>
                        <div class="text-muted small">@AppState.T("View all system data", "تمام سسٹم ڈیٹا دیکھیں")</div>
                    </div>
                    <span class="oi oi-chevron-right text-muted"></span>
                </button>
            </div>
            <div class="col-12 col-md-6">
                <button class="card p-3 shadow-sm border-0 w-100 text-start d-flex flex-row align-items-center" @onclick='() => SetView("Add")' style="border: none; cursor: pointer;">
                    <span class="bg-light text-primary p-3 rounded-3 me-3"><span class="oi oi-plus"></span></span>
                    <div class="flex-fill">
                        <div class="fw-bold">@AppState.T("Add New Record", "نیا ریکارڈ درج کریں")</div>
                        <div class="text-muted small">@AppState.T("Add new data entry", "نئی معلومات درج کریں")</div>
                    </div>
                    <span class="oi oi-chevron-right text-muted"></span>
                </button>
            </div>
            <div class="col-12 col-md-6">
                <button class="card p-3 shadow-sm border-0 w-100 text-start d-flex flex-row align-items-center" @onclick='() => SetView("EditList")' style="border: none; cursor: pointer;">
                    <span class="bg-light p-3 rounded-3 me-3" style="color: #673AB7;"><span class="oi oi-pencil"></span></span>
                    <div class="flex-fill">
                        <div class="fw-bold">@AppState.T("Edit Records", "ریکارڈز تبدیل کریں")</div>
                        <div class="text-muted small">@AppState.T("Update existing records", "موجودہ معلومات کو اپ ڈیٹ کریں")</div>
                    </div>
                    <span class="oi oi-chevron-right text-muted"></span>
                </button>
            </div>
            <div class="col-12 col-md-6">
                <button class="card p-3 shadow-sm border-0 w-100 text-start d-flex flex-row align-items-center" @onclick='() => SetView("DeleteList")' style="border: none; cursor: pointer;">
                    <span class="bg-light text-danger p-3 rounded-3 me-3"><span class="oi oi-trash"></span></span>
                    <div class="flex-fill">
                        <div class="fw-bold">@AppState.T("Delete Records", "ریکارڈز حذف کریں")</div>
                        <div class="text-muted small">@AppState.T("Remove data", "ڈیٹا کو ہٹا دیں")</div>
                    </div>
                    <span class="oi oi-chevron-right text-muted"></span>
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="card p-3 p-md-4 shadow-sm border-0">
            <div class="d-flex align-items-center gap-2 mb-3 pb-3 border-bottom">
                <button class="btn btn-sm btn-outline-secondary" @onclick='() => SetView("None")'>
                    <span class="oi oi-arrow-left"></span>
                </button>
                <h3 class="fs-5 fw-bold mb-0" style="color: #673AB7;">@(AppState.IsUrdu ? TranslateViewTitle(_activeView) : _viewTitle)</h3>
            </div>

            @if (_activeView == "DataGrid")
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>@AppState.T("Date", "تاریخ")</th>
                                <th>@AppState.T("Crop", "فصل")</th>
                                <th>@AppState.T("Description", "تفصیل")</th>
                                <th>@AppState.T("Tag", "ٹیگ / کیٹیگری")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in AdvisoryService.Search(null, null, "All Crops"))
                            {
                                <tr>
                                    <td>@TranslateDate(item.Date)</td>
                                    <td class="fw-bold">@(AppState.IsUrdu ? TranslateCropName(item.CropName) : item.CropName)</td>
                                    <td class="text-muted small">@(AppState.IsUrdu ? TranslateDescription(item.Description) : item.Description)</td>
                                    <td>
                                        <span class="badge @GetTagClass(item.Tag)">@(AppState.IsUrdu ? TranslateTag(item.Tag) : item.Tag)</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else if (_activeView == "Add" || _activeView == "EditForm")
            {
                <div class="mx-auto" style="max-width: 480px;">
                    <div class="mb-3">
                        <label class="form-label fw-bold">@AppState.T("Date", "تاریخ")</label>
                        <input type="date" class="form-control w-100" @bind="_formRecord.Date" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">@AppState.T("Crop Name", "فصل کا نام")</label>
                        <input type="text" class="form-control w-100" placeholder='@AppState.T("e.g. Rice, Wheat", "مثال کے طور پر: چاول، گندم")' @bind="_formRecord.CropName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">@AppState.T("Tag", "ٹیگ / کیٹیگری")</label>
                        <select class="form-select w-100" @bind="_formRecord.Tag">
                            <option value="Fertilizer">@AppState.T("Fertilizer", "کھاد کا استعمال")</option>
                            <option value="Pest Control">@AppState.T("Pest Control", "کیڑوں سے بچاؤ")</option>
                            <option value="Irrigation">@AppState.T("Irrigation", "آبپاشی / پانی دینا")</option>
                            <option value="Harvesting">@AppState.T("Harvesting", "کٹائی")</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">@AppState.T("Description", "تفصیل")</label>
                        <textarea class="form-control w-100" placeholder='@AppState.T("Enter advisory advice...", "زرعی مشورہ درج کریں...")' @bind="_formRecord.Description" rows="3"></textarea>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_validationError))
                    {
                        <div class="alert alert-danger py-2 small">@(AppState.IsUrdu ? TranslateValidationError(_validationError) : _validationError)</div>
                    }

                    <div class="d-flex gap-2">
                        <button class="btn btn-success flex-fill fw-bold" @onclick="SaveRecord">@AppState.T("Save", "محفوظ کریں")</button>
                        <button class="btn btn-secondary flex-fill fw-bold" @onclick='() => SetView("None")'>@AppState.T("Cancel", "منسوخ کریں")</button>
                    </div>
                </div>
            }
            else if (_activeView == "EditList")
            {
                <div class="d-flex flex-column gap-2">
                    @foreach (var item in AdvisoryService.Search(null, null, "All Crops"))
                    {
                        <div class="d-flex align-items-center gap-2 p-3 border rounded">
                            <div class="flex-fill" style="min-width: 0;">
                                <div class="fw-bold small">@(AppState.IsUrdu ? TranslateCropName(item.CropName) : item.CropName) - <span class="fw-normal text-muted">@TranslateDate(item.Date)</span></div>
                                <div class="text-muted small text-truncate">@(AppState.IsUrdu ? TranslateDescription(item.Description) : item.Description)</div>
                            </div>
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => EditRecord(item)">
                                <span class="oi oi-pencil"></span>
                            </button>
                        </div>
                    }
                </div>
            }
            else if (_activeView == "DeleteList")
            {
                <div class="d-flex flex-column gap-2">
                    @foreach (var item in AdvisoryService.Search(null, null, "All Crops"))
                    {
                        <div class="d-flex align-items-center gap-2 p-3 border rounded">
                            <div class="flex-fill" style="min-width: 0;">
                                <div class="fw-bold small">@(AppState.IsUrdu ? TranslateCropName(item.CropName) : item.CropName) - <span class="fw-normal text-muted">@TranslateDate(item.Date)</span></div>
                                <div class="text-muted small text-truncate">@(AppState.IsUrdu ? TranslateDescription(item.Description) : item.Description)</div>
                            </div>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteRecord(item.Id)">
                                <span class="oi oi-trash"></span>
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }
}

@code {
    private bool _showProfileMenu = false;
    private string _activeView = "None"; // None, DataGrid, Add, EditList, EditForm, DeleteList
    private string _viewTitle = "";
    private string _validationError = "";
    private bool _loading = false;
    private string _errorMessage;

    private AdvisoryRecord _formRecord = new AdvisoryRecord();

    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
    }

    private async Task ToggleProfileMenu()
    {
        try
        {
            _showProfileMenu = !_showProfileMenu;
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to toggle profile menu: " + ex.Message;
        }
        await Task.CompletedTask;
    }

    private async Task ClearError()
    {
        _errorMessage = null;
        await Task.CompletedTask;
    }

    private async Task SetView(string view)
    {
        try
        {
            _loading = true;
            _errorMessage = null;
            _validationError = "";
            _showProfileMenu = false;

            // Simulate minor navigation loading delay
            await Task.Delay(150);

            _activeView = view;

            _viewTitle = view switch
            {
                "DataGrid" => "Data Grid",
                "Add" => "Add Advisory",
                "EditList" => "Select Record to Edit",
                "EditForm" => "Edit Advisory",
                "DeleteList" => "Delete Records",
                _ => ""
            };

            if (view == "Add")
            {
                _formRecord = new AdvisoryRecord
                {
                    Date = DateTime.Today,
                    Tag = "Fertilizer"
                };
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to navigate: " + ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task EditRecord(AdvisoryRecord item)
    {
        try
        {
            _formRecord = new AdvisoryRecord
            {
                Id = item.Id,
                Date = item.Date,
                CropName = item.CropName,
                Description = item.Description,
                Tag = item.Tag
            };
            await SetView("EditForm");
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to open edit details: " + ex.Message;
        }
    }

    private async Task SaveRecord()
    {
        if (string.IsNullOrWhiteSpace(_formRecord.CropName))
        {
            _validationError = "Crop name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_formRecord.Description))
        {
            _validationError = "Description is required.";
            return;
        }

        try
        {
            _loading = true;
            _errorMessage = null;
            await Task.Delay(300); // Simulate save network lag

            if (_activeView == "Add")
            {
                AdvisoryService.AddAdvisory(_formRecord);
            }
            else if (_activeView == "EditForm")
            {
                AdvisoryService.UpdateAdvisory(_formRecord);
            }

            await SetView("None");
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to save record: " + ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task DeleteRecord(int id)
    {
        try
        {
            _loading = true;
            _errorMessage = null;
            await Task.Delay(300); // Simulate delete delay

            AdvisoryService.DeleteAdvisory(id);
            // If list is now empty, reset view, otherwise stay on delete view
            if (!AdvisoryService.Search(null, null, "All Crops").Any())
            {
                await SetView("None");
            }
            else
            {
                await SetView("DeleteList");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to delete record: " + ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private string GetTagClass(string tag)
    {
        return tag?.ToLower() switch
        {
            "fertilizer" => "bg-primary",
            "pest control" => "bg-danger",
            "irrigation" => "bg-info text-dark",
            "harvesting" => "bg-success",
            _ => "bg-secondary"
        };
    }

    private string TranslateViewTitle(string view) => view switch
    {
        "DataGrid" => "ڈیٹا گرڈ",
        "Add" => "نیا مشورہ درج کریں",
        "EditList" => "ترمیم کے لیے ریکارڈ منتخب کریں",
        "EditForm" => "مشورے میں ترمیم کریں",
        "DeleteList" => "ریکارڈز حذف کریں",
        _ => ""
    };

    private string TranslateValidationError(string err) => err switch
    {
        "Crop name is required." => "فصل کا نام درج کرنا لازمی ہے۔",
        "Description is required." => "تفصیل درج کرنا لازمی ہے۔",
        _ => err
    };

    private string TranslateCropName(string name)
    {
        if (string.IsNullOrEmpty(name)) return "";
        return name switch
        {
            "Wheat" => "گندم",
            "Cotton" => "کپاس",
            "Rice" => "چاول / دھان",
            "Sugarcane" => "گنا",
            "Maize" => "مکئی",
            "Potato" => "آلو",
            "Tomato" => "ٹماٹر",
            "Onion" => "پیاز",
            "Chili" or "Chilli" => "مرچ",
            "Citrus" => "مالٹا",
            "Mango" => "آم",
            "Sunflower" => "سورج مکھی",
            "Soybean" => "سویا بین",
            "Millet" => "باجرہ",
            "Sorghum" => "جوار",
            "Sesame" => "تل",
            "Barley" => "جو",
            "Chickpea" or "Gram" => "چنا",
            "Lentil" => "مسور",
            "Mustard" => "سرسوں",
            "Spinach" => "پالک",
            "Carrot" => "گاجر",
            _ => name
        };
    }

    private string TranslateTag(string tag)
    {
        if (string.IsNullOrEmpty(tag)) return "";
        return tag switch
        {
            "Fertilizer" => "کھاد کا استعمال",
            "Pest Control" => "کیڑوں سے بچاؤ",
            "Irrigation" => "آبپاشی / پانی دینا",
            "Harvesting" => "کٹائی",
            _ => tag
        };
    }

    private string TranslateDate(DateTime date)
    {
        if (AppState.IsUrdu)
        {
            var day = date.Day.ToString();
            var month = date.Month switch
            {
                1 => "جنوری",
                2 => "فروری",
                3 => "مارچ",
                4 => "اپریل",
                5 => "مئی",
                6 => "جون",
                7 => "جولائی",
                8 => "اگست",
                9 => "ستمبر",
                10 => "اکتوبر",
                11 => "نومبر",
                12 => "دسمبر",
                _ => ""
            };
            var year = date.Year.ToString();
            return $"{day} {month} {year}";
        }
        else
        {
            return date.ToString("dd/MM/yyyy");
        }
    }

    private string TranslateDescription(string desc)
    {
        if (string.IsNullOrEmpty(desc)) return "";
        return desc switch
        {
            "Apply nitrogen fertilizer in the morning." => "صبح کے وقت نائٹروجن کھاد ڈالیں۔",
            "Monitor for whitefly and spray neem oil." => "سفید مکھی کی نگرانی کریں اور نیم کے تیل کا سپرے کریں۔",
            "Irrigation recommended after 7 days." => "7 دن بعد آبپاشی کی سفارش کی جاتی ہے۔",
            "Harvest crop when grains are hard." => "جب دانے سخت ہو جائیں تو فصل کی کٹائی کریں۔",
            "Apply potash fertilizer at tillering stage." => "شگوفے نکلنے کے مرحلے پر پوٹاش کھاد ڈالیں۔",
            "Inspect fields for stem borer moths." => "کھیتوں کا تنا چھیدنے والے کیڑے کے لیے معائنہ کریں۔",
            "Schedule drip irrigation every 5 days." => "ہر 5 دن بعد ڈرپ آبپاشی کا شیڈول بنایں۔",
            "Harvest pods when they turn yellow-brown." => "جب پھلیاں پیلی بھوری ہو جائیں تو کٹائی کریں۔",
            "Apply DAP fertilizer at sowing time." => "بوائی کے وقت ڈی اے پی کھاد کا استعمال کریں۔",
            "Watch for rust disease on leaves." => "پتوں پر کنگی کی بیماری (Rust) کا دھیان رکھیں۔",
            "Ensure standing water depth of 5 cm." => "کھڑے پانی کی گہرائی 5 سینٹی میٹر یقینی بنائیں۔",
            "Cut mature cane at ground level." => "پکی ہوئی گنے کی کٹائی زمین کے برابر کریں۔",
            "Top-dress urea fertilizer before final irrigation." => "آخری آبپاشی سے پہلے یوریا کھاد ڈالیں۔",
            "Spray fungicide to prevent late blight disease." => "پھپھوندی کش دوا سپرے کریں تاکہ پچھیتا جھلساؤ (Late Blight) بیماری سے بچا جا سکے۔",
            "First irrigation 30-35 days after sowing." => "بوائی کے 30 سے 35 دن بعد پہلی آبپاشی کریں۔",
            "Harvest maize when husks turn paper-like and grains are dry." => "مکئی کی کٹائی تب کریں جب چھلکے کاغذ جیسے ہو جائیں اور دانے خشک ہو جائیں۔",
            "Apply nitrogenous fertilizer in three split doses." => "نائٹروجن والی کھاد تین الگ قسطوں میں ڈالیں۔",
            "Use yellow sticky cards to capture whiteflies." => "سفید مکھیوں کو پکڑنے کے لیے پیلے رنگ کے چمٹیلے کارڈز استعمال کریں۔",
            "Maintain water level during tillering stage." => "شگوفے بننے کے دوران پانی کی سطح برقرار رکھیں۔",
            "Harvest when grain moisture content drops below 14%." => "کٹائی تب کریں جب دانوں میں نمی کا تناسب 14 فیصد سے کم ہو جائے۔",
            "Apply compost and zinc sulfate around tree basins." => "درخت کے گرد کیاریوں میں نامیاتی کھاد اور زنک سلفیٹ ڈالیں۔",
