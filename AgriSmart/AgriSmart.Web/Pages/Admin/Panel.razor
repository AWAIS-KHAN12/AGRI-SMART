@page "/admin/panel"
@attribute [Authorize(Roles = "Admin")]
@inject AdvisoryService AdvisoryService
@inject NavigationManager NavigationManager

<div class="app-shell">
    @* ── Header ── *@
    <header class="app-header purple">
        <button class="btn-icon" title="Menu" @onclick="ToggleSidebar">
            <span class="oi oi-menu"></span>
        </button>
        <h1>Admin Panel</h1>
        <button class="btn-icon" title="User Profile" @onclick="ToggleProfileMenu">
            <span class="oi oi-person"></span>
        </button>
    </header>

    @* ── Sidebar Drawer ── *@
    @if (_showSidebar)
    {
        <div class="sidebar-overlay" @onclick="ToggleSidebar">
            <div class="sidebar-drawer" @onclick:stopPropagation>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; border-bottom: 1px solid var(--card-border); padding-bottom: 0.75rem;">
                    <div style="font-weight: 700; color: var(--purple-admin);">AGRI-SMART</div>
                    <button class="btn-icon" style="color: var(--text-dark); min-width: 36px; min-height: 36px;" @onclick="ToggleSidebar">
                        <span class="oi oi-x"></span>
                    </button>
                </div>
                <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                    <a href="/admin/panel" class="active" style="background: var(--green-light); font-weight: 600; color: var(--green-dark);" @onclick="ToggleSidebar">
                        <span class="oi oi-dashboard" style="margin-right: 0.75rem;"></span>
                        Admin Panel
                    </a>
                    <a href="/farmer/dashboard" @onclick="ToggleSidebar">
                        <span class="oi oi-home" style="margin-right: 0.75rem;"></span>
                        Farmer Dashboard
                    </a>
                    <a href="/farmer/advisory" @onclick="ToggleSidebar">
                        <span class="oi oi-spreadsheet" style="margin-right: 0.75rem;"></span>
                        Advisory History
                    </a>
                    <hr style="border: 0; border-top: 1px solid var(--card-border); margin: 1rem 0;" />
                    <a href="/logout" style="color: #c62828;">
                        <span class="oi oi-account-logout" style="margin-right: 0.75rem;"></span>
                        Logout
                    </a>
                </div>
            </div>
        </div>
    }

    @* ── Profile Menu Popup ── *@
    @if (_showProfileMenu)
    {
        <div class="sidebar-overlay" @onclick="ToggleProfileMenu">
            <div style="position: absolute; right: 10px; top: 60px; background: white; border-radius: 12px; box-shadow: 0 4px 16px rgba(0,0,0,.15); padding: 1rem; width: 200px; z-index: 150;" @onclick:stopPropagation>
                <div style="font-weight: 700; font-size: 0.9rem; margin-bottom: 0.25rem;">Administrator</div>
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.75rem;">admin@agrismart.pk</div>
                <hr style="border: 0; border-top: 1px solid var(--card-border); margin: 0.5rem 0;" />
                <a href="/logout" class="btn-green-full" style="background: #c62828; margin: 0; display: block; text-align: center; text-decoration: none; font-size: 0.85rem; padding: 0.5rem 0; min-height: auto;">
                    Logout
                </a>
            </div>
        </div>
    }

    @* ── Scrollable Content ── *@
    <div class="app-content cream">
        @if (_activeView == "None")
        {
            @* ── STATS SECTION ── *@
            <div class="admin-stats">
                <div class="admin-stat-card">
                    <span class="stat-value" style="color: #2E7D32;">
                        <span class="oi oi-people" style="margin-right: 2px;"></span> 125
                    </span>
                    <div class="stat-label">Total Farmers</div>
                </div>
                <div class="admin-stat-card">
                    <span class="stat-value" style="color: #1976D2;">
                        <span class="oi oi-location" style="margin-right: 2px;"></span> 18
                    </span>
                    <div class="stat-label">Active Regions</div>
                </div>
                <div class="admin-stat-card">
                    <span class="stat-value" style="color: #F9A825;">
                        <span class="oi oi-lightbulb" style="margin-right: 2px;"></span> @AdvisoryService.TotalAdvisories
                    </span>
                    <div class="stat-label">Advisories</div>
                </div>
            </div>

            <div class="admin-stats-row2">
                <div class="admin-stat-card">
                    <span class="stat-value" style="color: #673AB7;">
                        <span class="oi oi-document" style="margin-right: 2px;"></span> 8
                    </span>
                    <div class="stat-label">Reports</div>
                </div>
            </div>

            @* ── MANAGEMENT SECTION ── *@
            <h3 class="section-title">Management</h3>

            <button class="mgmt-card" @onclick='() => SetView("DataGrid")' style="width: 100%; border: none; text-align: left;">
                <span style="background: #EDE7F6; color: #673AB7; padding: 0.5rem; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center;">
                    <span class="oi oi-list-rich" style="font-size: 1.1rem;"></span>
                </span>
                <div style="flex: 1;">
                    <div class="ql-title" style="font-weight: 600;">Data Grid</div>
                    <div class="ql-desc" style="font-size: 0.75rem; color: var(--text-muted);">View all system data</div>
                </div>
                <span class="oi oi-chevron-right" style="color: var(--text-muted);"></span>
            </button>

            <button class="mgmt-card" @onclick='() => SetView("Add")' style="width: 100%; border: none; text-align: left;">
                <span style="background: #E3F2FD; color: #1976D2; padding: 0.5rem; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center;">
                    <span class="oi oi-plus" style="font-size: 1.1rem;"></span>
                </span>
                <div style="flex: 1;">
                    <div class="ql-title" style="font-weight: 600;">Add New Record</div>
                    <div class="ql-desc" style="font-size: 0.75rem; color: var(--text-muted);">Add new data entry</div>
                </div>
                <span class="oi oi-chevron-right" style="color: var(--text-muted);"></span>
            </button>

            <button class="mgmt-card" @onclick='() => SetView("EditList")' style="width: 100%; border: none; text-align: left;">
                <span style="background: #EDE7F6; color: #673AB7; padding: 0.5rem; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center;">
                    <span class="oi oi-pencil" style="font-size: 1.1rem;"></span>
                </span>
                <div style="flex: 1;">
                    <div class="ql-title" style="font-weight: 600;">Edit Records</div>
                    <div class="ql-desc" style="font-size: 0.75rem; color: var(--text-muted);">Update existing records</div>
                </div>
                <span class="oi oi-chevron-right" style="color: var(--text-muted);"></span>
            </button>

            <button class="mgmt-card" @onclick='() => SetView("DeleteList")' style="width: 100%; border: none; text-align: left;">
                <span style="background: #FFEBEE; color: #C62828; padding: 0.5rem; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center;">
                    <span class="oi oi-trash" style="font-size: 1.1rem;"></span>
                </span>
                <div style="flex: 1;">
                    <div class="ql-title" style="font-weight: 600;">Delete Records</div>
                    <div class="ql-desc" style="font-size: 0.75rem; color: var(--text-muted);">Remove data</div>
                </div>
                <span class="oi oi-chevron-right" style="color: var(--text-muted);"></span>
            </button>
        }
        else
        {
            @* ── Dynamic Sub-Views (Data Grid, Add, Edit, Delete) ── *@
            <div style="background: #fff; border-radius: 16px; padding: 1.25rem; box-shadow: 0 4px 12px rgba(0,0,0,.05); border: 1px solid var(--card-border);">
                <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; border-bottom: 1px solid var(--card-border); padding-bottom: 0.75rem;">
                    <button class="btn-icon" style="color: var(--text-dark); min-width: 36px; min-height: 36px; display: flex;" @onclick='() => SetView("None")'>
                        <span class="oi oi-arrow-left"></span>
                    </button>
                    <h3 style="font-weight: 700; margin: 0; font-size: 1.15rem; color: var(--purple-admin);">@_viewTitle</h3>
                </div>

                @if (_activeView == "DataGrid")
                {
                    <div class="table-responsive">
                        <table class="table table-striped" style="margin-bottom: 0; width: 100%;">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Crop</th>
                                    <th>Description</th>
                                    <th>Tag</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in AdvisoryService.Search(null, null, "All Crops"))
                                {
                                    <tr>
                                        <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                        <td style="font-weight: 600;">@item.CropName</td>
                                        <td style="font-size: 0.75rem; color: var(--text-muted);">@item.Description</td>
                                        <td>
                                            <span class="tag-badge @GetTagClass(item.Tag)" style="position: static; font-size: 0.6rem; padding: 0.15rem 0.35rem; display: inline-block;">
                                                @item.Tag
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (_activeView == "Add" || _activeView == "EditForm")
                {
                    <div class="mobile-form" style="display: flex; flex-direction: column; gap: 0.85rem;">
                        <div>
                            <label>Date</label>
                            <input type="date" class="form-control" @bind="_formRecord.Date" style="width: 100%; padding: 0.5rem;" />
                        </div>
                        <div>
                            <label>Crop Name</label>
                            <input type="text" class="form-control" placeholder="e.g. Rice, Wheat" @bind="_formRecord.CropName" style="width: 100%; padding: 0.5rem;" />
                        </div>
                        <div>
                            <label>Tag</label>
                            <select class="form-control" @bind="_formRecord.Tag" style="width: 100%; padding: 0.5rem; background: white;">
                                <option value="Fertilizer">Fertilizer</option>
                                <option value="Pest Control">Pest Control</option>
                                <option value="Irrigation">Irrigation</option>
                                <option value="Harvesting">Harvesting</option>
                            </select>
                        </div>
                        <div>
                            <label>Description</label>
                            <textarea class="form-control" placeholder="Enter advisory advice..." @bind="_formRecord.Description" rows="3" style="width: 100%; padding: 0.5rem;"></textarea>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_validationError))
                        {
                            <div class="validation-message" style="margin-top: 0.25rem;">@_validationError</div>
                        }

                        <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                            <button class="btn-search-green" style="margin: 0; flex: 1;" @onclick="SaveRecord">Save</button>
                            <button class="btn-green-full" style="margin: 0; flex: 1; background: #9e9e9e;" @onclick='() => SetView("None")'>Cancel</button>
                        </div>
                    </div>
                }
                else if (_activeView == "EditList")
                {
                    <div style="display: flex; flex-direction: column; gap: 0.65rem;">
                        @foreach (var item in AdvisoryService.Search(null, null, "All Crops"))
                        {
                            <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.65rem; border: 1px solid var(--card-border); border-radius: 8px;">
                                <div style="flex: 1; min-width: 0;">
                                    <div style="font-weight: 700; font-size: 0.85rem;">@item.CropName - <span style="font-weight: 400; color: var(--text-muted);">@item.Date.ToString("dd/MM/yyyy")</span></div>
                                    <div style="font-size: 0.75rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@item.Description</div>
                                </div>
                                <button class="btn-icon" style="color: var(--blue-primary); min-width: 36px; min-height: 36px;" @onclick="() => EditRecord(item)">
                                    <span class="oi oi-pencil"></span>
                                </button>
                            </div>
                        }
                    </div>
                }
                else if (_activeView == "DeleteList")
                {
                    <div style="display: flex; flex-direction: column; gap: 0.65rem;">
                        @foreach (var item in AdvisoryService.Search(null, null, "All Crops"))
                        {
                            <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.65rem; border: 1px solid var(--card-border); border-radius: 8px;">
                                <div style="flex: 1; min-width: 0;">
                                    <div style="font-weight: 700; font-size: 0.85rem;">@item.CropName - <span style="font-weight: 400; color: var(--text-muted);">@item.Date.ToString("dd/MM/yyyy")</span></div>
                                    <div style="font-size: 0.75rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@item.Description</div>
                                </div>
                                <button class="btn-icon" style="color: #c62828; min-width: 36px; min-height: 36px;" @onclick="() => DeleteRecord(item.Id)">
                                    <span class="oi oi-trash"></span>
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private bool _showSidebar = false;
    private bool _showProfileMenu = false;
    private string _activeView = "None"; // None, DataGrid, Add, EditList, EditForm, DeleteList
    private string _viewTitle = "";
    private string _validationError = "";

    private AdvisoryRecord _formRecord = new AdvisoryRecord();

    private void ToggleSidebar()
    {
        _showSidebar = !_showSidebar;
        if (_showSidebar) _showProfileMenu = false;
    }

    private void ToggleProfileMenu()
    {
        _showProfileMenu = !_showProfileMenu;
        if (_showProfileMenu) _showSidebar = false;
    }

    private void SetView(string view)
    {
        _activeView = view;
        _validationError = "";
        _showSidebar = false;
        _showProfileMenu = false;

        _viewTitle = view switch
        {
            "DataGrid" => "Data Grid",
            "Add" => "Add Advisory",
            "EditList" => "Select Record to Edit",
            "EditForm" => "Edit Advisory",
            "DeleteList" => "Delete Records",
            _ => ""
        };

        if (view == "Add")
        {
            _formRecord = new AdvisoryRecord
            {
                Date = DateTime.Today,
                Tag = "Fertilizer"
            };
        }
    }

    private void EditRecord(AdvisoryRecord item)
    {
        _formRecord = new AdvisoryRecord
        {
            Id = item.Id,
            Date = item.Date,
            CropName = item.CropName,
            Description = item.Description,
            Tag = item.Tag
        };
        SetView("EditForm");
    }

    private void SaveRecord()
    {
        if (string.IsNullOrWhiteSpace(_formRecord.CropName))
        {
            _validationError = "Crop name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_formRecord.Description))
        {
            _validationError = "Description is required.";
            return;
        }

        if (_activeView == "Add")
        {
            AdvisoryService.AddAdvisory(_formRecord);
        }
        else if (_activeView == "EditForm")
        {
            AdvisoryService.UpdateAdvisory(_formRecord);
        }

        SetView("None");
    }

    private void DeleteRecord(int id)
    {
        AdvisoryService.DeleteAdvisory(id);
        // If list is now empty, reset view, otherwise stay on delete view
        if (!AdvisoryService.Search(null, null, "All Crops").Any())
        {
            SetView("None");
        }
    }

    private string GetTagClass(string tag)
    {
        return tag?.ToLower() switch
        {
            "fertilizer" => "tag-fertilizer",
            "pest control" => "tag-pest",
            "irrigation" => "tag-irrigation",
            "harvesting" => "tag-harvest",
            _ => "tag-fertilizer"
        };
    }
}
