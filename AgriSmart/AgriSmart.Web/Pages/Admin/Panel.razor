@page "/admin/panel"
@attribute [Authorize(Roles = "Admin")]
@inject AdvisoryService AdvisoryService
@inject NavigationManager NavigationManager

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fs-4 fw-bold mb-0">Admin Panel</h2>
    <div class="position-relative">
        <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleProfileMenu">
            <span class="oi oi-person me-1"></span> Profile
        </button>
        @if (_showProfileMenu)
        {
            <div class="position-absolute end-0 mt-2 bg-white rounded shadow p-3" style="z-index: 1050; width: 220px;">
                <div class="fw-bold small">Administrator</div>
                <div class="text-muted small mb-2">admin@agrismart.pk</div>
                <hr class="my-2" />
                <a href="/logout" class="btn btn-danger btn-sm w-100">Logout</a>
            </div>
        }
    </div>
</div>

@if (_activeView == "None")
{
    @* Stats *@
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card p-3 p-md-4 shadow-sm border-0 text-center h-100">
                <span class="oi oi-people text-success fs-3 mb-2"></span>
                <div class="fs-4 fw-bold text-success">125</div>
                <div class="text-muted small">Total Farmers</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card p-3 p-md-4 shadow-sm border-0 text-center h-100">
                <span class="oi oi-location text-primary fs-3 mb-2"></span>
                <div class="fs-4 fw-bold text-primary">18</div>
                <div class="text-muted small">Active Regions</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card p-3 p-md-4 shadow-sm border-0 text-center h-100">
                <span class="oi oi-lightbulb text-warning fs-3 mb-2"></span>
                <div class="fs-4 fw-bold text-warning">@AdvisoryService.TotalAdvisories</div>
                <div class="text-muted small">Advisories</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card p-3 p-md-4 shadow-sm border-0 text-center h-100">
                <span class="oi oi-document fs-3 mb-2" style="color: #673AB7;"></span>
                <div class="fs-4 fw-bold" style="color: #673AB7;">8</div>
                <div class="text-muted small">Reports</div>
            </div>
        </div>
    </div>

    @* Management *@
    <h3 class="fs-5 fw-bold mb-3">Management</h3>
    <div class="row g-3">
        <div class="col-12 col-md-6">
            <button class="card p-3 shadow-sm border-0 w-100 text-start d-flex flex-row align-items-center" @onclick='() => SetView("DataGrid")' style="border: none; cursor: pointer;">
                <span class="bg-light p-3 rounded-3 me-3" style="color: #673AB7;"><span class="oi oi-list-rich"></span></span>
                <div class="flex-fill">
                    <div class="fw-bold">Data Grid</div>
                    <div class="text-muted small">View all system data</div>
                </div>
                <span class="oi oi-chevron-right text-muted"></span>
            </button>
        </div>
        <div class="col-12 col-md-6">
            <button class="card p-3 shadow-sm border-0 w-100 text-start d-flex flex-row align-items-center" @onclick='() => SetView("Add")' style="border: none; cursor: pointer;">
                <span class="bg-light text-primary p-3 rounded-3 me-3"><span class="oi oi-plus"></span></span>
                <div class="flex-fill">
                    <div class="fw-bold">Add New Record</div>
                    <div class="text-muted small">Add new data entry</div>
                </div>
                <span class="oi oi-chevron-right text-muted"></span>
            </button>
        </div>
        <div class="col-12 col-md-6">
            <button class="card p-3 shadow-sm border-0 w-100 text-start d-flex flex-row align-items-center" @onclick='() => SetView("EditList")' style="border: none; cursor: pointer;">
                <span class="bg-light p-3 rounded-3 me-3" style="color: #673AB7;"><span class="oi oi-pencil"></span></span>
                <div class="flex-fill">
                    <div class="fw-bold">Edit Records</div>
                    <div class="text-muted small">Update existing records</div>
                </div>
                <span class="oi oi-chevron-right text-muted"></span>
            </button>
        </div>
        <div class="col-12 col-md-6">
            <button class="card p-3 shadow-sm border-0 w-100 text-start d-flex flex-row align-items-center" @onclick='() => SetView("DeleteList")' style="border: none; cursor: pointer;">
                <span class="bg-light text-danger p-3 rounded-3 me-3"><span class="oi oi-trash"></span></span>
                <div class="flex-fill">
                    <div class="fw-bold">Delete Records</div>
                    <div class="text-muted small">Remove data</div>
                </div>
                <span class="oi oi-chevron-right text-muted"></span>
            </button>
        </div>
    </div>
}
else
{
    <div class="card p-3 p-md-4 shadow-sm border-0">
        <div class="d-flex align-items-center gap-2 mb-3 pb-3 border-bottom">
            <button class="btn btn-sm btn-outline-secondary" @onclick='() => SetView("None")'>
                <span class="oi oi-arrow-left"></span>
            </button>
            <h3 class="fs-5 fw-bold mb-0" style="color: #673AB7;">@_viewTitle</h3>
        </div>

        @if (_activeView == "DataGrid")
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Crop</th>
                            <th>Description</th>
                            <th>Tag</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in AdvisoryService.Search(null, null, "All Crops"))
                        {
                            <tr>
                                <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                <td class="fw-bold">@item.CropName</td>
                                <td class="text-muted small">@item.Description</td>
                                <td>
                                    <span class="badge @GetTagClass(item.Tag)">@item.Tag</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else if (_activeView == "Add" || _activeView == "EditForm")
        {
            <div class="mx-auto" style="max-width: 480px;">
                <div class="mb-3">
                    <label class="form-label fw-bold">Date</label>
                    <input type="date" class="form-control w-100" @bind="_formRecord.Date" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Crop Name</label>
                    <input type="text" class="form-control w-100" placeholder="e.g. Rice, Wheat" @bind="_formRecord.CropName" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Tag</label>
                    <select class="form-select w-100" @bind="_formRecord.Tag">
                        <option value="Fertilizer">Fertilizer</option>
                        <option value="Pest Control">Pest Control</option>
                        <option value="Irrigation">Irrigation</option>
                        <option value="Harvesting">Harvesting</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Description</label>
                    <textarea class="form-control w-100" placeholder="Enter advisory advice..." @bind="_formRecord.Description" rows="3"></textarea>
                </div>

                @if (!string.IsNullOrWhiteSpace(_validationError))
                {
                    <div class="alert alert-danger py-2 small">@_validationError</div>
                }

                <div class="d-flex gap-2">
                    <button class="btn btn-success flex-fill fw-bold" @onclick="SaveRecord">Save</button>
                    <button class="btn btn-secondary flex-fill fw-bold" @onclick='() => SetView("None")'>Cancel</button>
                </div>
            </div>
        }
        else if (_activeView == "EditList")
        {
            <div class="d-flex flex-column gap-2">
                @foreach (var item in AdvisoryService.Search(null, null, "All Crops"))
                {
                    <div class="d-flex align-items-center gap-2 p-3 border rounded">
                        <div class="flex-fill" style="min-width: 0;">
                            <div class="fw-bold small">@item.CropName - <span class="fw-normal text-muted">@item.Date.ToString("dd/MM/yyyy")</span></div>
                            <div class="text-muted small text-truncate">@item.Description</div>
                        </div>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => EditRecord(item)">
                            <span class="oi oi-pencil"></span>
                        </button>
                    </div>
                }
            </div>
        }
        else if (_activeView == "DeleteList")
        {
            <div class="d-flex flex-column gap-2">
                @foreach (var item in AdvisoryService.Search(null, null, "All Crops"))
                {
                    <div class="d-flex align-items-center gap-2 p-3 border rounded">
                        <div class="flex-fill" style="min-width: 0;">
                            <div class="fw-bold small">@item.CropName - <span class="fw-normal text-muted">@item.Date.ToString("dd/MM/yyyy")</span></div>
                            <div class="text-muted small text-truncate">@item.Description</div>
                        </div>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteRecord(item.Id)">
                            <span class="oi oi-trash"></span>
                        </button>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private bool _showProfileMenu = false;
    private string _activeView = "None"; // None, DataGrid, Add, EditList, EditForm, DeleteList
    private string _viewTitle = "";
    private string _validationError = "";

    private AdvisoryRecord _formRecord = new AdvisoryRecord();

    private void ToggleProfileMenu()
    {
        _showProfileMenu = !_showProfileMenu;
    }

    private void SetView(string view)
    {
        _activeView = view;
        _validationError = "";
        _showProfileMenu = false;

        _viewTitle = view switch
        {
            "DataGrid" => "Data Grid",
            "Add" => "Add Advisory",
            "EditList" => "Select Record to Edit",
            "EditForm" => "Edit Advisory",
            "DeleteList" => "Delete Records",
            _ => ""
        };

        if (view == "Add")
        {
            _formRecord = new AdvisoryRecord
            {
                Date = DateTime.Today,
                Tag = "Fertilizer"
            };
        }
    }

    private void EditRecord(AdvisoryRecord item)
    {
        _formRecord = new AdvisoryRecord
        {
            Id = item.Id,
            Date = item.Date,
            CropName = item.CropName,
            Description = item.Description,
            Tag = item.Tag
        };
        SetView("EditForm");
    }

    private void SaveRecord()
    {
        if (string.IsNullOrWhiteSpace(_formRecord.CropName))
        {
            _validationError = "Crop name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_formRecord.Description))
        {
            _validationError = "Description is required.";
            return;
        }

        if (_activeView == "Add")
        {
            AdvisoryService.AddAdvisory(_formRecord);
        }
        else if (_activeView == "EditForm")
        {
            AdvisoryService.UpdateAdvisory(_formRecord);
        }

        SetView("None");
    }

    private void DeleteRecord(int id)
    {
        AdvisoryService.DeleteAdvisory(id);
        // If list is now empty, reset view, otherwise stay on delete view
        if (!AdvisoryService.Search(null, null, "All Crops").Any())
        {
            SetView("None");
        }
    }

    private string GetTagClass(string tag)
    {
        return tag?.ToLower() switch
        {
            "fertilizer" => "bg-primary",
            "pest control" => "bg-danger",
            "irrigation" => "bg-info text-dark",
            "harvesting" => "bg-success",
            _ => "bg-secondary"
        };
    }
}
